# Azure AI Search
AZURE_SEARCH_ENDPOINT=https://your-search-resource.search.windows.net
AZURE_SEARCH_KEY=your-search-admin-key
AZURE_SEARCH_INDEX_NAME=meridian-ai-governance

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://your-openai-resource.openai.azure.com
AZURE_OPENAI_KEY=your-openai-key
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-ada-002
AZURE_OPENAI_API_VERSION=2024-02-01

# Search configuration
SEMANTIC_CONFIG_NAME=semantic-config
CONFIDENCE_THRESHOLD=0.7
TOP_K_RESULTS=5

# Document processing
KNOWLEDGE_BASE_PATH=./knowledge-base
CHUNK_SIZE_TOKENS=512
CHUNK_OVERLAP_RATIO=0.2

# Audit logging
AUDIT_LOG_PATH=./audit/audit_log.jsonl

# Optional: SharePoint audit integration (production)
SHAREPOINT_SITE_URL=https://meridian.sharepoint.com/sites/ai-governance
SHAREPOINT_LIST_NAME=AI-Governance-Audit
SHAREPOINT_TENANT_ID=your-tenant-id
SHAREPOINT_CLIENT_ID=your-client-id
SHAREPOINT_CLIENT_SECRET=your-client-secret
